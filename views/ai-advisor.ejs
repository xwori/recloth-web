<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI-Стилист — Recloth</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .ai-container { max-width: 700px; margin: 230px auto 100px; padding: 40px; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); text-align: center; }
        .ai-title { font-family: 'Playfair Display', serif; font-size: 2.5rem; color: #333; margin-bottom: 10px; }
        .ai-subtitle { color: #666; margin-bottom: 30px; font-size: 1.1rem; line-height: 1.6; }
        
        .upload-area { border: 2px dashed #D4AF37; border-radius: 15px; padding: 40px; cursor: pointer; transition: all 0.3s; margin-bottom: 20px; background: #fafafa; }
        .upload-area:hover { background: #fff8e7; }
        .upload-area img { max-width: 100%; max-height: 300px; border-radius: 10px; display: none; margin: 0 auto; }
        
        .btn-ai { background: #D4AF37; color: white; border: none; padding: 15px 30px; font-size: 1.1rem; border-radius: 30px; cursor: pointer; font-weight: 600; transition: all 0.3s; width: 100%; margin-top: 10px;}
        .btn-ai:hover { background: #b5952f; transform: translateY(-2px); }
        .btn-ai:disabled { background: #ccc; cursor: not-allowed; transform: none; }
        
        .ai-result { margin-top: 30px; padding: 25px; background: #f8f9fa; border-radius: 15px; text-align: left; display: none; line-height: 1.7; font-size: 1.05rem; color: #333; border-left: 5px solid #D4AF37;}
        .loader { display: none; margin: 20px auto; border: 4px solid #f3f3f3; border-top: 4px solid #D4AF37; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <header class="header" id="header">
        <div class="container">
            <div class="header-content">
                <a href="/" class="logo-link">
                    <img src="/images/logotip.jpg" alt="Recloth virtual stylist" class="logo">
                </a>
                <nav class="nav" id="nav">
                    <div class="nav-content">
                        <a href="/" class="nav-link">На главную</a>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <div class="container">
        <div class="ai-container">
            <h1 class="ai-title">AI-Советник</h1>
            <p class="ai-subtitle">Опиши свою вещь, задай вопрос или загрузи фото — наш ИИ подскажет лучшие идеи для апсайклинга!</p>
            
            <form id="aiForm">
                <textarea id="questionInput" rows="3" placeholder="Опишите вашу вещь или задайте вопрос по апсайклингу..." style="width: 100%; padding: 15px; border-radius: 15px; border: 1px solid #ddd; margin-bottom: 20px; font-family: inherit; font-size: 1rem; resize: none; box-sizing: border-box;"></textarea>

                <div class="upload-area" id="uploadArea" onclick="document.getElementById('photoInput').click()">
                    <p id="uploadText">📸 Нажми сюда, чтобы прикрепить фото (необязательно)</p>
                    <img id="previewImage" src="" alt="Превью">
                </div>
                <input type="file" id="photoInput" accept="image/*" style="display: none;" onchange="previewFile()">
                
                <button type="submit" class="btn-ai" id="submitBtn">Спросить у ИИ ✨</button>
            </form>

            <div class="loader" id="loader"></div>
            <div class="ai-result" id="aiResult"></div>
        </div>
    </div>

    <script>
        function previewFile() {
            const preview = document.getElementById('previewImage');
            const file = document.getElementById('photoInput').files[0];
            const uploadText = document.getElementById('uploadText');
            
            if (file) {
                const reader = new FileReader();
                reader.onloadend = function () {
                    preview.src = reader.result;
                    preview.style.display = 'block';
                    uploadText.style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        }

        document.getElementById('aiForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const fileInput = document.getElementById('photoInput');
            const questionInput = document.getElementById('questionInput').value.trim();
            
            if (!fileInput.files[0] && questionInput === '') {
                return alert('Пожалуйста, напишите вопрос или загрузите фото!');
            }

            const formData = new FormData();
            if (fileInput.files[0]) formData.append('photo', fileInput.files[0]);
            if (questionInput) formData.append('question', questionInput);

            const submitBtn = document.getElementById('submitBtn');
            const loader = document.getElementById('loader');
            const resultDiv = document.getElementById('aiResult');

            submitBtn.disabled = true;
            submitBtn.innerText = 'Нейросеть думает...';
            loader.style.display = 'block';
            resultDiv.style.display = 'none';

            try {
                const response = await fetch('/api/analyze-photo', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();

                if (response.ok) {
                    resultDiv.innerHTML = data.advice.replace(/\n/g, '<br>');
                    resultDiv.style.display = 'block';
                } else {
                    alert(data.error || 'Произошла ошибка');
                }
            } catch (err) {
                alert('Произошла ошибка сети');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerText = 'Спросить у ИИ ✨';
                loader.style.display = 'none';
            }
        });
    </script>
</body>
</html>