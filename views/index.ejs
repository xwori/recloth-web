<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Идеи апсайклинга, статьи, мастер-классы по обновлению одежды. Recloth — сообщество для переработки и обновления старой одежды.">
    <meta name="theme-color" content="#F8F9FA">
    <title>Recloth — Усовершенствуй старую одежду | Upcycling идеи</title>
    <!-- Исправленные пути к статике -->
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/png" href="/images/logotip.jpg" sizes="32x32">
</head>
<body>
    <header class="header" id="header">
        <div class="container">
            <div class="header-content">
                <a href="#hero" class="logo-link">
                    <img src="/images/logotip.jpg" alt="Recloth virtual stylist" class="logo">
                </a>
                <nav class="nav" id="nav">
                    <div class="nav-content">
                        <a href="#hero" class="nav-link">Главная</a>
                        <a href="#about" class="nav-link">О проекте</a>
                        <a href="#articles" class="nav-link">Статьи</a>
                        <a href="#video-lessons" class="nav-link">Видео</a> 
                        <a href="#ideas" class="nav-link">Идеи</a>
                        <a href="/quizzes" class="nav-link">Опросы</a>
                        <a href="#gallery" class="nav-link">Галерея</a>
                        <a href="#contacts" class="nav-link">Контакты</a>
                    </div>
                </nav>
                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Меню">
                    <span></span><span></span><span></span>
                </button>
            </div>
        </div>
    </header>

    <section class="hero" id="hero">
        <div class="hero-background"></div>
        <div class="container">
            <div class="hero-content">
                <h1 class="hero-title">Recloth: Дыши новой жизнью в старую одежду!</h1>
                <h2 class="hero-subtitle">Обнови, добавь, создай уникальное. Эко-мода своими руками.</h2>
                <div class="hero-buttons">
                    <a href="#ideas" class="btn btn-primary">Смотреть идеи</a>
                    <a href="/quizzes" class="btn btn-secondary" style="background: #6200ee; color: white; border: none;">Пройти тест</a>
                    <a href="#video-lessons" class="btn btn-secondary">Смотреть видео</a>
                </div>
            </div>
        </div>
    </section>

    <section class="about" id="about">
        <div class="container">
            <h2 class="section-title">О проекте</h2>
            <div class="about-content">
                <p class="about-text">
                    Recloth — сообщество для апсайклинга. Мы показываем, как превратить старую футболку в сумку, 
                    джинсы в шорты с аппликацией или пальто в стильный жакет. Экономь, твори, береги планету!
                </p>
                <div class="about-cards">
                    <div class="about-card fade-in">
                        <div class="about-card-icon">💰</div>
                        <h3 class="about-card-title">ЭКОНОМИЯ</h3>
                        <p class="about-card-text">Сэкономь 80% на новой одежде</p>
                    </div>
                    <div class="about-card fade-in">
                        <div class="about-card-icon">🌿</div>
                        <h3 class="about-card-title">ЭКОЛОГИЯ</h3>
                        <p class="about-card-text">Меньше отходов = чище планета</p>
                    </div>
                    <div class="about-card fade-in">
                        <div class="about-card-icon">💡</div>
                        <h3 class="about-card-title">КРЕАТИВ</h3>
                        <p class="about-card-text">Каждая вещь — уникальный дизайн</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="articles" id="video-lessons" style="background: #fff;">
        <div class="container">
            <h2 class="section-title">Видео мастер-классы</h2>
            <div class="articles-grid" id="videoGrid"></div>
        </div>
    </section>

    <section class="articles" id="articles">
        <div class="container">
            <h2 class="section-title">Статьи и мастер-классы</h2>
            <div class="articles-grid" id="articlesGrid"></div>
        </div>
    </section>

    <section class="ideas" id="ideas">
        <div class="container">
            <h2 class="section-title">Идеи трансформаций</h2>
            <div class="ideas-grid" id="ideasGrid"></div>
        </div>
    </section>

    <section class="gallery" id="gallery">
        <div class="container">
            <h2 class="section-title">Галерея работ</h2>
            <div class="gallery-grid" id="galleryGrid"></div>
        </div>
    </section>

    <section class="howto" id="howto">
        <div class="container">
            <h2 class="section-title">Как начать</h2>
            <div class="howto-steps">
                <div class="howto-step fade-in">
                    <div class="howto-number">1️⃣</div>
                    <h3 class="howto-title">Выбери вещь</h3>
                    <p class="howto-text">Найди в шкафу то, что больше не носишь</p>
                </div>
                <div class="howto-step fade-in">
                    <div class="howto-number">2️⃣</div>
                    <h3 class="howto-title">Ищи идеи</h3>
                    <p class="howto-text">Изучи наши мастер-классы и вдохновись примерами</p>
                </div>
                <div class="howto-step fade-in">
                    <div class="howto-number">3️⃣</div>
                    <h3 class="howto-title">Добавь материалы</h3>
                    <p class="howto-text">Подготовь нитки, ножницы и всё необходимое</p>
                </div>
                <div class="howto-step fade-in">
                    <div class="howto-number">4️⃣</div>
                    <h3 class="howto-title">Поделись #recloth</h3>
                    <p class="howto-text">Покажи результат в нашей галерее</p>
                </div>
            </div>
        </div>
    </section>

    <section class="form-section" id="form">
        <div class="container">
            <h2 class="section-title">Хочешь в галерею? Покажи результат!</h2>
            <form class="contact-form" id="contactForm" action="/api/gallery" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="name">Имя</label>
                    <input type="text" id="name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="photo">Фото работы</label>
                    <input type="file" id="photo" name="photo" accept="image/*" required>
                </div>
                <div class="form-group">
                    <label for="description">Описание</label>
                    <textarea id="description" name="description" rows="5" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Отправить</button>
            </form>
        </div>
    </section>

    <section class="contacts" id="contacts">
        <div class="container">
            <h2 class="section-title">Контакты</h2>
            <div class="contacts-content">
                <div class="contacts-list">
                    <a href="https://t.me/upcycling_recloth" class="contact-item" target="_blank" rel="noopener">
                        <span class="contact-icon">📢</span>
                        <span class="contact-text">Telegram канал: t.me/upcycling_recloth</span>
                    </a>
                    <a href="https://t.me/TexelReclothBot" class="contact-item" target="_blank" rel="noopener">
                        <span class="contact-icon">🤖</span>
                        <span class="contact-text">AI-бот: @TexelReclothBot</span>
                    </a>
                    <a href="https://instagram.com/recloth" class="contact-item" target="_blank" rel="noopener">
                        <span class="contact-icon">📸</span>
                        <span class="contact-text">Instagram: @recloth</span>
                    </a>
                    <a href="mailto:hello@recloth.ru" class="contact-item">
                        <span class="contact-icon">✉️</span>
                        <span class="contact-text">Email: hello@recloth.ru</span>
                    </a>
                </div>
                <div class="contacts-map">
                    <div class="map-placeholder">
                        <p>🗺️ Москва</p>
                        <p class="map-note">Yandex Maps</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <p class="footer-text">© 2026 Recloth</p>
                <div class="footer-links">
                    <a href="https://t.me/upcycling_recloth" target="_blank" rel="noopener">t.me/upcycling_recloth</a>
                    <a href="https://t.me/TexelReclothBot" target="_blank" rel="noopener">@TexelReclothBot</a>
                </div>
            </div>
        </div>
    </footer>

    <div class="modal" id="galleryModal">
        <div class="modal-content">
            <span class="modal-close" id="modalClose">&times;</span>
            <img src="" alt="" id="modalImage">
            <a href="#articles" class="modal-link">Подробнее в статье</a>
        </div>
    </div>

    <!-- Ссылка на внешний скрипт -->
    <script src="/script.js"></script>

    <script>
        async function loadContent() {
            try {
                const response = await fetch('/api/articles');
                const articles = await response.json();
                
                const articlesGrid = document.getElementById('articlesGrid');
                const videoGrid = document.getElementById('videoGrid');
                
                if (articlesGrid) articlesGrid.innerHTML = '';
                if (videoGrid) videoGrid.innerHTML = '';

                articles.forEach(article => {
                    const card = document.createElement('article');
                    card.className = 'article-card fade-in visible';
                    
                    // Умный поиск картинки: сначала featured, потом первая из галереи, потом заглушка
                    let previewImage = '/images/default.jpg';
                    if (article.featured_image) {
                        previewImage = article.featured_image;
                    } else if (article.images && article.images.length > 0) {
                        previewImage = article.images[0].image_url;
                    }
                    
                    const articleLink = `/article?slug=${article.slug}`;

                    // Генерируем карточку: всегда картинка, никогда не видео на главной
                    card.innerHTML = `
                        <div class="article-image">
                            <img src="${previewImage}" alt="${article.title}">
                        </div>
                        <div class="article-content">
                            <h3 class="article-title">${article.title}</h3>
                            <p class="article-excerpt">${article.excerpt}</p>
                            <a href="${articleLink}" class="article-link">
                                ${article.video_url ? 'Смотреть детали →' : 'Читать полностью →'}
                            </a>
                        </div>
                    `;

                    // Распределяем карточки
                    if (article.video_url && videoGrid) {
                        videoGrid.appendChild(card);
                    } else if (articlesGrid) {
                        articlesGrid.appendChild(card);
                    }
                });

                const galleryResponse = await fetch('/api/gallery');
                const galleryItems = await galleryResponse.json();
                const galleryGrid = document.getElementById('galleryGrid');
                
                if (galleryGrid) {
                    galleryGrid.innerHTML = '';
                    galleryItems.forEach(item => {
                        const div = document.createElement('div');
                        div.className = 'gallery-item fade-in visible';
                        div.innerHTML = `
                            <img src="${item.image_url}" alt="${item.title}" onclick="openModal(this.src)">
                            <div class="gallery-overlay">
                                <a href="#articles" class="gallery-link">Подробнее →</a>
                            </div>
                        `;
                        galleryGrid.appendChild(div);
                    });
                }

                const ideasResponse = await fetch('/api/ideas');
                const ideas = await ideasResponse.json();
                const ideasGrid = document.getElementById('ideasGrid');
                
                if (ideasGrid) {
                    ideasGrid.innerHTML = '';
                    ideas.forEach(idea => {
                        const div = document.createElement('div');
                        div.className = 'idea-card fade-in visible';
                        div.innerHTML = `
                            <div class="idea-images">
                                <div class="idea-before">
                                    <img src="${idea.image_before || ''}" alt="До">
                                    <span class="idea-label">ДО</span>
                                </div>
                                <div class="idea-arrow">→</div>
                                <div class="idea-after">
                                    <img src="${idea.image_after || ''}" alt="После">
                                    <span class="idea-label">ПОСЛЕ</span>
                                </div>
                            </div>
                            <div class="idea-content">
                                <h3 class="idea-title">${idea.title}</h3>
                                <p class="idea-materials">Материалы: ${idea.materials.map(m => m.name).join(', ')}</p>
                                <a href="#articles" class="idea-link">Подробнее в статье</a>
                            </div>
                        `;
                        ideasGrid.appendChild(div);
                    });
                }

            } catch (err) {
                console.error('Ошибка загрузки данных:', err);
            }
        }

        function openModal(src) {
            const modal = document.getElementById('galleryModal');
            const modalImg = document.getElementById('modalImage');
            if (modal && modalImg) {
                modalImg.src = src;
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        }

        document.getElementById('modalClose').onclick = () => {
            document.getElementById('galleryModal').classList.remove('active');
            document.body.style.overflow = '';
        };

        document.addEventListener('DOMContentLoaded', loadContent);
    </script>
</body>
</html>