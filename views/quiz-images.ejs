<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тест: Знаток Апсайклинга — Recloth</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/images/logotip.jpg" sizes="32x32">
    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            background-color: #f8f9fa;
        }

        /* Оптимальный отступ, чтобы контент был виден под шапкой */
        .quiz-wrapper {
            flex: 1;
            padding-top: 380px; 
            padding-bottom: 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .quiz-card {
            background: #ffffff;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.1);
            text-align: center;
            width: 90%;
            max-width: 700px;
            border: 1px solid #eaeaea;
        }

        .section-title {
            color: #2c3e50;
            margin-bottom: 20px;
            font-family: 'Playfair Display', serif;
            font-size: 26px;
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 25px;
        }

        .option-btn {
            padding: 16px;
            border: 2px solid #edf2f7;
            border-radius: 10px;
            background: #fff;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            font-size: 15px;
            color: #4a5568;
        }

        .option-btn:hover {
            border-color: #D4AF37;
            background: #fffcf0;
            transform: translateY(-2px);
        }

        .progress-bar {
            width: 90%;
            max-width: 700px;
            height: 10px;
            background: #e2e8f0;
            border-radius: 20px;
            margin-bottom: 20px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: #D4AF37;
            width: 0%;
            transition: width 0.4s ease;
        }

        #result-screen { display: none; }

        @media (max-width: 768px) {
            .quiz-wrapper { padding-top: 220px; }
            .options-grid { grid-template-columns: 1fr; }
            .quiz-card { padding: 25px; }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <a href="/" class="logo-link">
                    <img src="/images/logotip.jpg" alt="Logo" class="logo">
                </a>
                <nav class="nav">
                    <div class="nav-content">
                        <a href="/" class="nav-link">Главная</a>
                        <a href="/quizzes" class="nav-link">Опросы</a>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <main class="quiz-wrapper container">
        <div class="progress-bar">
            <div class="progress-fill" id="progress"></div>
        </div>
        
        <div id="question-screen" class="quiz-card">
            <h2 id="question-text" class="section-title">Инициализация...</h2>
            <div class="options-grid" id="options"></div>
        </div>

        <div id="result-screen" class="quiz-card">
            <h2 class="section-title">Готово!</h2>
            <p id="result-text" style="font-size: 22px; margin: 25px 0; font-family: 'Inter', sans-serif; color: #2d3748;"></p>
            <a href="/quizzes" class="btn btn-primary" style="background: #D4AF37; border: none; padding: 14px 40px; color: white; text-decoration: none; border-radius: 8px; font-weight: bold; display: inline-block;">К другим опросам</a>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <p class="footer-text">© 2026 Recloth</p>
                <div class="footer-links">
                    <a href="https://t.me/upcycling_recloth" target="_blank">t.me/upcycling_recloth</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const quizData = [
                {
                    q: "ЧТО ОЗНАЧАЕТ ТЕРМИН «АПСАЙКЛИНГ»?",
                    options: ["УТИЛИЗАЦИЯ МУСОРА", "ПОВТОРНОЕ ИСПОЛЬЗОВАНИЕ ВЕЩЕЙ С УЛУЧШЕНИЕМ ИХ КАЧЕСТВА", "СЖИГАНИЕ ОТХОДОВ", "СКЛАДИРОВАНИЕ МУСОРА"],
                    correct: 1
                },
                {
                    q: "ЧЕМ АПСАЙКЛИНГ ОТЛИЧАЕТСЯ ОТ ПЕРЕРАБОТКИ?",
                    options: ["НИЧЕМ НЕ ОТЛИЧАЕТСЯ", "ПРИ АПСАЙКЛИНГЕ ВЕЩЬ ИСПОЛЬЗУЕТСЯ БЕЗ ИЗМЕНЕНИЙ", "ПРИ АПСАЙКЛИНГЕ СОЗДАЁТСЯ НОВАЯ ВЕЩЬ С БОЛЬШЕЙ ЦЕННОСТЬЮ", "ПЕРЕРАБОТКА ВСЕГДА ДОРОЖЕ"],
                    correct: 2
                },
                {
                    q: "ЧТО ИЗ ПЕРЕЧИСЛЕННОГО ЯВЛЯЕТСЯ ПРИМЕРОМ АПСАЙКЛИНГА?",
                    options: ["ВЫБРОС СТАРОЙ ОДЕЖДЫ", "ПЕРЕРАБОТКА ПЛАСТИКА НА ЗАВОДЕ", "СОЗДАНИЕ СУМКИ ИЗ СТАРЫХ ДЖИНСОВ", "СЖИГАНИЕ БУМАГИ"],
                    correct: 2
                },
                {
                    q: "ЗАЧЕМ НУЖЕН АПСАЙКЛИНГ?",
                    options: ["ЧТОБЫ УВЕЛИЧИТЬ КОЛИЧЕСТВО ОТХОДОВ", "ЧТОБЫ ЭКОНОМИТЬ РЕСУРСЫ И УМЕНЬШАТЬ МУСОР", "ЧТОБЫ УСКОРИТЬ ПРОИЗВОДСТВО", "ЧТОБЫ УПРОСТИТЬ УТИЛИЗАЦИЮ"],
                    correct: 1
                },
                {
                    q: "ЧТО ЧАЩЕ ВСЕГО ИСПОЛЬЗУЮТ ДЛЯ АПСАЙКЛИНГА?",
                    options: ["ТОЛЬКО НОВЫЕ МАТЕРИАЛЫ", "СТАРЫЕ ИЛИ НЕНУЖНЫЕ ВЕЩИ", "ТОЛЬКО ПЛАСТИК", "ТОЛЬКО СТЕКЛО"],
                    correct: 1
                }
            ];

            let index = 0;
            let score = 0;

            function renderQuestion() {
                const current = quizData[index];
                document.getElementById('question-text').innerText = current.q;
                const optionsBox = document.getElementById('options');
                optionsBox.innerHTML = '';
                
                current.options.forEach((text, i) => {
                    const button = document.createElement('button');
                    button.className = 'option-btn';
                    button.innerText = text;
                    button.onclick = () => handleChoice(i);
                    optionsBox.appendChild(button);
                });
                
                const progressValue = (index / quizData.length) * 100;
                document.getElementById('progress').style.width = progressValue + '%';
            }

            function handleChoice(choice) {
                if (choice === quizData[index].correct) {
                    score++;
                }
                index++;
                if (index < quizData.length) {
                    renderQuestion();
                } else {
                    finishQuiz();
                }
            }

            function finishQuiz() {
                document.getElementById('question-screen').style.display = 'none';
                document.getElementById('progress').style.width = '100%';
                const resultBox = document.getElementById('result-screen');
                resultBox.style.display = 'block';
                document.getElementById('result-text').innerText = 'Ты набрал ' + score + ' очков из ' + quizData.length + '!';
            }

            renderQuestion();
        });
    </script>
</body>
</html>