<body>
    <header class="header" id="header">
        <div class="container">
            <div class="header-content">
                <a href="#hero" class="logo-link">
                    <img src="/images/logotip.jpg" alt="Recloth virtual stylist" class="logo">
                </a>
                <nav class="nav" id="nav">
                    <div class="nav-content">
                        <a href="#hero" class="nav-link">Главная</a>
                        <a href="#about" class="nav-link">О проекте</a>
                        <a href="#articles" class="nav-link">Статьи</a>
                        <a href="#video-lessons" class="nav-link">Видео</a> 
                        <a href="/ai-advisor" class="nav-link" style="color: #D4AF37; font-weight: bold;">AI-Советник</a>
                        <a href="/quizzes" class="nav-link">Опросы</a>
                        <a href="#contacts" class="nav-link">Контакты</a>
                    </div>
                </nav>
                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Меню">
                    <span></span><span></span><span></span>
                </button>
            </div>
