<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Тест: Знаток Апсайклинга — Recloth</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/images/logotip.jpg" sizes="32x32">
    <style>
        /* Базовая настройка для прижатия футера */
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            background-color: #f8f9fa;
        }

        /* ОГРОМНЫЙ ОТСТУП, ЧТОБЫ ТЕСТ БЫЛ ПОСЕРЕДИНЕ */
        .quiz-wrapper {
            flex: 1;
            padding-top: 1050px; /* Сдвигаем тест максимально низко */
            padding-bottom: 200px;
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }

        .quiz-card {
            background: #ffffff;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            text-align: center;
            width: 90%;
            max-width: 800px;
            border: 1px solid #ddd;
        }

        .section-title {
            color: #2c3e50;
            margin-bottom: 30px;
            font-family: 'Playfair Display', serif;
            font-size: 30px;
        }

        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 30px;
        }

        .option-btn {
            padding: 20px;
            border: 2px solid #edf2f7;
            border-radius: 12px;
            background: #fff;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            font-size: 16px;
            color: #333;
            line-height: 1.4;
        }

        .option-btn:hover {
            border-color: #D4AF37;
            background: #fffdf5;
            transform: translateY(-3px);
        }

        .progress-bar {
            width: 90%;
            max-width: 800px;
            height: 12px;
            background: #e2e8f0;
            border-radius: 20px;
            margin-bottom: 30px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: #D4AF37;
            width: 0%;
            transition: width 0.4s ease;
        }

        #result-screen { display: none; }

        @media (max-width: 768px) {
            .quiz-wrapper { padding-top: 280px; }
            .options-grid { grid-template-columns: 1fr; }
            .section-title { font-size: 24px; }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <a href="/" class="logo-link">
                    <img src="/images/logotip.jpg" alt="Logo" class="logo">
                </a>
                <nav class="nav">
                    <div class="nav-content">
                        <a href="/" class="nav-link">Главная</a>
                        <a href="/quizzes" class="nav-link">Опросы</a>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <main class="quiz-wrapper container">
        <div class="progress-bar">
            <div class="progress-fill" id="progress"></div>
        </div>
        
        <div id="question-screen" class="quiz-card">
            <h2 id="question-text" class="section-title">Загрузка...</h2>
            <div class="options-grid" id="options"></div>
        </div>

        <div id="result-screen" class="quiz-card">
            <h2 class="section-title">Тест пройден!</h2>
            <p id="result-text" style="font-size: 24px; margin: 30px 0; font-family: 'Inter', sans-serif; font-weight: bold;"></p>
            <a href="/quizzes" class="btn btn-primary" style="background: #D4AF37; border: none; padding: 15px 45px; color: white; text-decoration: none; border-radius: 8px; font-weight: bold; display: inline-block;">Вернуться назад</a>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <p class="footer-text">© 2026 Recloth</p>
                <div class="footer-links">
                    <a href="https://t.me/upcycling_recloth" target="_blank">t.me/upcycling_recloth</a>
                </div>
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const data = [
                {
                    q: "ЧТО ОЗНАЧАЕТ ТЕРМИН «АПСАЙКЛИНГ»?",
                    options: ["УТИЛИЗАЦИЯ МУСОРА", "ПОВТОРНОЕ ИСПОЛЬЗОВАНИЕ ВЕЩЕЙ С УЛУЧШЕНИЕМ ИХ КАЧЕСТВА", "СЖИГАНИЕ ОТХОДОВ", "СКЛАДИРОВАНИЕ МУСОРА"],
                    correct: 1
                },
                {
                    q: "ЧЕМ АПСАЙКЛИНГ ОТЛИЧАЕТСЯ ОТ ПЕРЕРАБОТКИ?",
                    options: ["НИЧЕМ НЕ ОТЛИЧАЕТСЯ", "ПРИ АПСАЙКЛИНГЕ ВЕЩЬ ИСПОЛЬЗУЕТСЯ БЕЗ ИЗМЕНЕНИЙ", "ПРИ АПСАЙКЛИНГЕ СОЗДАЁТСЯ НОВАЯ ВЕЩЬ С БОЛЬШЕЙ ЦЕННОСТЬЮ", "ПЕРЕРАБОТКА ВСЕГДА ДОРОЖЕ"],
                    correct: 2
                },
                {
                    q: "ЧТО ИЗ ПЕРЕЧИСЛЕННОГО ЯВЛЯЕТСЯ ПРИМЕРОМ АПСАЙКЛИНГА?",
                    options: ["ВЫБРОС СТАРОЙ ОДЕЖДЫ", "ПЕРЕРАБОТКА ПЛАСТИКА НА ЗАВОДЕ", "СОЗДАНИЕ СУМКИ ИЗ СТАРЫХ ДЖИНСОВ", "СЖИГАНИЕ БУМАГИ"],
                    correct: 2
                },
                {
                    q: "ЗАЧЕМ НУЖЕН АПСАЙКЛИНГ?",
                    options: ["ЧТОБЫ УВЕЛИЧИТЬ КОЛИЧЕСТВО ОТХОДОВ", "ЧТОБЫ ЭКОНОМИТЬ РЕСУРСЫ И УМЕНЬШАТЬ МУСОР", "ЧТОБЫ УСКОРИТЬ ПРОИЗВОДСТВО", "ЧТОБЫ УПРОСТИТЬ УТИЛИЗАЦИЮ"],
                    correct: 1
                },
                {
                    q: "ЧТО ЧАЩЕ ВСЕГО ИСПОЛЬЗУЮТ ДЛЯ АПСАЙКЛИНГА?",
                    options: ["ТОЛЬКО НОВЫЕ МАТЕРИАЛЫ", "СТАРЫЕ ИЛИ НЕНУЖНЫЕ ВЕЩИ", "ТОЛЬКО ПЛАСТИК", "ТОЛЬКО СТЕКЛО"],
                    correct: 1
                }
            ];

            let cur = 0;
            let res = 0;

            function next() {
                const item = data[cur];
                document.getElementById('question-text').innerText = item.q;
                const box = document.getElementById('options');
                box.innerHTML = '';
                
                item.options.forEach((txt, i) => {
                    const b = document.createElement('button');
                    b.className = 'option-btn';
                    b.innerText = txt;
                    b.onclick = () => {
                        if (i === item.correct) res++;
                        cur++;
                        if (cur < data.length) {
                            next();
                        } else {
                            document.getElementById('question-screen').style.display = 'none';
                            document.getElementById('result-screen').style.display = 'block';
                            document.getElementById('result-text').innerText = 'Результат: ' + res + ' из ' + data.length;
                        }
                    };
                    box.appendChild(b);
                });
                
                document.getElementById('progress').style.width = (cur / data.length * 100) + '%';
            }

            next();
        });
    </script>
</body>
</html>