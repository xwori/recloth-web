                    джинсы в шорты с аппликацией или пальто в стильный жакет. Экономь, твори, береги планету!
                </p>
                <div class="about-cards">
                    <div class="about-card fade-in">
                        <div class="about-card-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        </div>
                        <h3 class="about-card-title">ЭКОНОМИЯ</h3>
                        <p class="about-card-text">Сэкономь 80% на новой одежде</p>
                    </div>
                    <div class="about-card fade-in">
                        <div class="about-card-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c4.97-4.97 9-10.26 9-15a9 9 0 0 0-18 0c0 4.74 4.03 10.03 9 15z"></path><path d="M12 22v-8"></path><path d="M12 14C8.69 14 6 11.31 6 8"></path></svg>
                        </div>
                        <h3 class="about-card-title">ЭКОЛОГИЯ</h3>
                        <p class="about-card-text">Меньше отходов = чище планета</p>
                    </div>
                    <div class="about-card fade-in">
                        <div class="about-card-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                        </div>
                        <h3 class="about-card-title">КРЕАТИВ</h3>
                        <p class="about-card-text">Каждая вещь — уникальный дизайн</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="articles" id="video-lessons" style="background: #fff;">
        <div class="container">
            <h2 class="section-title">Видео мастер-классы</h2>
            <div class="articles-grid" id="videoGrid"></div>
        </div>
    </section>

    <section class="articles" id="articles">
        <div class="container">
            <h2 class="section-title">Статьи и мастер-классы</h2>
            <div class="articles-grid" id="articlesGrid"></div>
        </div>
    </section>

    <section class="howto" id="howto">
        <div class="container">
            <h2 class="section-title">Как начать</h2>
            <div class="howto-steps">
                <div class="howto-step fade-in">
                    <div class="howto-number">01</div>
                    <h3 class="howto-title">Выбери вещь</h3>
                    <p class="howto-text">Найди в шкафу то, что больше не носишь</p>
                </div>
                <div class="howto-step fade-in">
                    <div class="howto-number">02</div>
                    <h3 class="howto-title">Ищи идеи</h3>
                    <p class="howto-text">Изучи наши мастер-классы и вдохновись примерами</p>
                </div>
                <div class="howto-step fade-in">
                    <div class="howto-number">03</div>
                    <h3 class="howto-title">Добавь материалы</h3>
                    <p class="howto-text">Подготовь нитки, ножницы и всё необходимое</p>
                </div>
                <div class="howto-step fade-in">
                    <div class="howto-number">04</div>
                    <h3 class="howto-title">Поделись #recloth</h3>
                    <p class="howto-text">Покажи результат в нашей галерее</p>
                </div>
            </div>
        </div>
    </section>

    <section class="contacts" id="contacts">
        <div class="container">
            <h2 class="section-title">Контакты</h2>
            <div class="contacts-content">
                <div class="contacts-list">
                    <a href="https://t.me/upcycling_recloth" class="contact-item" target="_blank" rel="noopener">
                        <span class="contact-icon">📢</span>
                        <span class="contact-text">Telegram канал: t.me/upcycling_recloth</span>
                    </a>
                    <a href="https://t.me/TexelReclothBot" class="contact-item" target="_blank" rel="noopener">
                        <span class="contact-icon">🤖</span>
                        <span class="contact-text">AI-бот: @TexelReclothBot</span>
                    </a>
                    <a href="https://instagram.com/recloth" class="contact-item" target="_blank" rel="noopener">
                        <span class="contact-icon">📸</span>
                        <span class="contact-text">Instagram: @recloth</span>
                    </a>
                    <a href="mailto:hello@recloth.ru" class="contact-item">
                        <span class="contact-icon">✉️</span>
                        <span class="contact-text">Email: hello@recloth.ru</span>
                    </a>
                </div>
                <div class="contacts-map">
                    <div class="map-placeholder">
                        <p>🗺️ Москва</p>
                        <p class="map-note">Yandex Maps</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <p class="footer-text">© 2026 Recloth</p>
                <div class="footer-links">
                    <a href="https://t.me/upcycling_recloth" target="_blank" rel="noopener">t.me/upcycling_recloth</a>
                    <a href="https://t.me/TexelReclothBot" target="_blank" rel="noopener">@TexelReclothBot</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="/script.js"></script>

    <script>
        async function loadContent() {
            try {
                const response = await fetch('/api/articles');
                const articles = await response.json();
                
                const articlesGrid = document.getElementById('articlesGrid');
                const videoGrid = document.getElementById('videoGrid');
                
                if (articlesGrid) articlesGrid.innerHTML = '';
                if (videoGrid) videoGrid.innerHTML = '';

                articles.forEach(article => {
                    const card = document.createElement('article');
                    card.className = 'article-card fade-in visible';
                    
                    if (article.video_url) {
                        card.innerHTML = `
                            <div class="article-image">
                                <video width="100%" poster="${article.featured_image || ''}" controls style="display:block">
                                    <source src="${article.video_url}" type="video/mp4">
                                </video>
                            </div>
                            <div class="article-content">
                                <h3 class="article-title">${article.title}</h3>
                                <p class="article-excerpt">${article.excerpt}</p>
                                <a href="/article?slug=${article.slug}" class="article-link">Смотреть детали →</a>
                            </div>
                        `;
                        if (videoGrid) videoGrid.appendChild(card);
                    } else {
                        card.innerHTML = `
                            <div class="article-image">
                                <img src="${article.featured_image || '/images/default.jpg'}" alt="${article.title}">
                            </div>
                            <div class="article-content">
                                <h3 class="article-title">${article.title}</h3>
                                <p class="article-excerpt">${article.excerpt}</p>
                                <a href="/article?slug=${article.slug}" class="article-link">Читать полностью →</a>
                            </div>
                        `;
                        if (articlesGrid) articlesGrid.appendChild(card);
                    }
                });

            } catch (err) {
                console.error('Ошибка загрузки данных:', err);
            }
        }

        document.addEventListener('DOMContentLoaded', loadContent);
    </script>
</body>
</html>